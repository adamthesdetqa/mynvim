#!/bin/bash

# Pre-commit hook to run Neovim configuration tests
echo "🏃 Running Neovim tests..."

# Run all PlenaryBusted tests in the tests/ directory headlessly
# PlenaryBustedDirectory automatically exits with code 1 if tests fail
nvim --headless -c "PlenaryBustedDirectory tests/"

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "❌ Tests failed! Commit aborted."
  echo "Fix the failing tests before committing, or use --no-verify to bypass."
  exit 1
fi

echo "✅ All tests passed!"
exit 0
